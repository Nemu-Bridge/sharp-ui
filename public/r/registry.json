          "foreground-subtle": "#64748b",
          "border-strong": "#cbd5e1",
          "border-focus": "#005bff",
          "surface-alt": "#f8fafc",
          "surface-hover": "#f1f5f9",
          "blue": "#005bff",
          "blue-hover": "#0048cc",
          "blue-active": "#003ba8",
